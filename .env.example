# ClawOSS Environment - copy to .env and fill in values
# DO NOT COMMIT .env - it is gitignored

# === Required ===

# GitHub Personal Access Token - needs public_repo scope at minimum
GITHUB_TOKEN=ghp_your-token-here

# Primary model in "<provider>/<model-id>" format.
# Examples:
#   openrouter/openai/gpt-4.1-mini
#   minimax/MiniMax-M2.7
#   kimi-coding/k2p5
CLAWOSS_MODEL_PRIMARY=openrouter/openai/gpt-4.1-mini

# OpenAI-compatible API base URL for the provider above.
# Examples:
#   https://openrouter.ai/api/v1
#   https://api.openai.com/v1
#   https://api.minimaxi.com/v1
CLAWOSS_LLM_BASE_URL=https://openrouter.ai/api/v1

# Unified API key used by the active provider.
# If empty, setup/restart will try OPENROUTER_API_KEY/OPENAI_API_KEY/
# ANTHROPIC_API_KEY/GEMINI_API_KEY/KIMI_API_KEY/MINIMAX_API_KEY in order.
CLAWOSS_LLM_API_KEY=sk-your-key-here

# === Optional model tuning ===

# Comma-separated fallback models (same provider as primary is recommended)
CLAWOSS_MODEL_FALLBACKS=

# Optional metadata for provider/model registry
CLAWOSS_MODEL_NAME=
CLAWOSS_MODEL_CONTEXT_WINDOW=204800
CLAWOSS_MODEL_MAX_TOKENS=131072
CLAWOSS_MODEL_REASONING=true

# Model pricing in USD per 1M tokens (for dashboard estimates)
CLAWOSS_MODEL_INPUT_COST_PER_MTOK=0.60
CLAWOSS_MODEL_OUTPUT_COST_PER_MTOK=3.00
CLAWOSS_MODEL_CACHE_READ_COST_PER_MTOK=
CLAWOSS_MODEL_CACHE_WRITE_COST_PER_MTOK=

# === Budget guardrail ===

# Total token budget for autonomous runtime (0 disables hard stop)
CLAWOSS_TOKEN_BUDGET_TOTAL=0

# === Optional ===

# GitHub identity for PRs (defaults shown)
GITHUB_USERNAME=BillionClaw
GITHUB_EMAIL=billionclaw+clawoss@users.noreply.github.com

# Dashboard (for dashboard-reporter skill)
DASHBOARD_URL=https://clawoss-dashboard.vercel.app
CLAW_API_KEY=your-shared-secret-here
